# App
APP_NAME=Aftertaste Backend
APP_ENV=local
DEBUG=false
API_V1_PREFIX=/v1
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aftertaste

# JWT
JWT_SECRET_KEY=change-me-to-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_FULL_MODEL=gpt-4o
OPENAI_CHAT_LITE_MODEL=gpt-4o-mini
OPENAI_BACKGROUND_MODEL=gpt-4o-mini

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# Open Banking (mock)
OPEN_BANKING_CLIENT_ID=
OPEN_BANKING_CLIENT_SECRET=
OPEN_BANKING_REDIRECT_URI=http://localhost:8000/v1/banking/oauth/callback
